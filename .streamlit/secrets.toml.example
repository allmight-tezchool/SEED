# このファイルを「secrets.toml」にリネームして使います。
# 本番(Streamlit Cloud)では Secrets画面に貼り付ける内容です。
# ローカル開発では基本不要(自動でローカルログインモードになる)。

[auth]
redirect_uri = "https://あなたのapp.streamlit.app/oauth2callback"
cookie_secret = "ここに長いランダム文字列を入れる(64文字以上推奨)"
client_id = "Google Cloud Console で取得した Client ID"
client_secret = "Google Cloud Console で取得した Client Secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# Anthropic APIキー
ANTHROPIC_API_KEY = "sk-ant-xxxx..."

# 許可ドメイン(空にすると誰でもログイン可能)
ALLOWED_EMAIL_DOMAIN = "yourcompany.co.jp"
